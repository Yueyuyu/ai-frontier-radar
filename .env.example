# 可选：GitHub 提高搜索 API 限额
GITHUB_TOKEN=

# 可选：X / Twitter Recent Search
X_BEARER_TOKEN=

# 可选：Product Hunt GraphQL API
PRODUCT_HUNT_TOKEN=

# 可选：Artificial Analysis Data API
ARTIFICIAL_ANALYSIS_API_KEY=
ARTIFICIAL_ANALYSIS_API_URL=

# 可选：MySQL 持久化，优先使用 DATABASE_URL
DATABASE_URL=jdbc:mysql://127.0.0.1:3306/ai_frontier_radar?useUnicode=true&characterEncoding=utf8&useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
DATABASE_USERNAME=root
DATABASE_PASSWORD=

# 可选：兼容拆分式数据库配置
DB_HOST=
DB_PORT=3306
DB_NAME=
DB_USERNAME=
DB_PASSWORD=
# 可选：前端聚合接口地址；不配置时跳过 API 并读取静态 JSON。配置为 / 时请求同源 /api/frontier/dataset。
VITE_API_BASE_URL=
