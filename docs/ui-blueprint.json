  "screens": [
    {
      "id": "overview",
      "route": "#overview",
      "title": "情报总览",
      "userGoal": "一屏判断当前 AI 前沿态势。",
      "layout": "desktop shell with sidebar, command bar, central signal matrix, right inspector, lower summary panels",
      "regions": [
        {
          "id": "summary",
          "component": "OverviewSummary",
          "data": ["stats.totalEntities", "stats.totalSources", "stats.verifiedSources", "generatedAt"]
        },
        {
          "id": "signalMatrix",
          "component": "SignalMatrix",
          "data": ["signals", "categoryMeta", "selectedSignalId"]
        },
        {
          "id": "signalInspector",
          "component": "SignalInspector",
          "data": ["selectedSignal", "selectedSignal.sources"]
        },
        {
          "id": "topSignals",
          "component": "SignalDock",
          "data": ["signals"]
        },
        {
          "id": "rankings",
          "component": "RankingPanel",
          "data": ["rankingItems"]
        },
        {
          "id": "sourceHealth",
          "component": "SourceHealthPanel",
          "data": ["sourceHealth"]
        },
        {
          "id": "sourceRuns",
          "component": "SourceRunPanel",
          "data": ["sourceRuns"]
        }
      ],
      "interactions": ["selectSignal", "filterCategory", "openSourceUrl", "goToFullList"]
    },
    {
      "id": "signals",
      "route": "#signals",
      "title": "前沿信号流",
      "userGoal": "筛选、排序和验证全部前沿信号。",
      "layout": "two column list and inspector",
      "regions": [
        {
          "id": "filters",
          "component": "SignalFilterBar",
          "data": ["categories", "confidenceLevels", "sourceTypes", "releaseWindows"]
        },
        {
          "id": "signalList",
          "component": "SignalList",
          "data": ["filteredSignals"]
        },
        {
          "id": "detail",
          "component": "SignalInspector",
          "data": ["selectedSignal"]
        }
      ],
      "states": ["loading", "emptyFiltered", "degradedDataset", "mobileDetailDrawer"]
    },
    {
      "id": "models",
      "route": "#model-rankings",
      "title": "模型地图",
      "userGoal": "查看模型发布、模型榜单和官方来源覆盖。",
      "layout": "feature header, ranking table, related signal list, data panel",
      "dataFilter": {
        "rankingItems.kind": "model",
        "signals.category": "模型",
        "dataPanels.id": "model-rankings"
      }
    },
    {
      "id": "agents",
      "route": "#agent-rankings",
      "title": "Agent 市场",
      "userGoal": "观察 Agent 产品、运行时和评测榜单。",
      "layout": "feature header, agent ranking table, signal list, source coverage",
      "dataFilter": {
        "rankingItems.kind": "agent",
        "signals.category": "Agent",
        "dataPanels.id": "agent-rankings"
      }
    },
    {
      "id": "skills",
      "route": "#tool-rankings",
      "title": "Skill / 插件",
      "userGoal": "追踪 MCP、Skill、开发者插件和工具生态。",
      "layout": "feature header, tool ranking table, ecosystem signals, source distribution",
      "dataFilter": {
        "rankingItems.kind": "tool",
        "signals.category": ["Skill / 插件", "AI 编程"],
        "dataPanels.id": "tool-rankings"
      }
    },
    {
      "id": "data",
      "route": "#source-runs",
      "title": "数据洞察",
      "userGoal": "检查刷新任务、数据库状态、数据分栏和失败来源。",
      "layout": "status header, source run list, data panel directory, missing credentials panel",
      "regions": [
        {
          "id": "databaseStatus",
          "component": "DatabaseStatusCard",
          "data": ["stats.databaseStatus"]
        },
        {
          "id": "sourceRuns",
          "component": "SourceRunList",
          "data": ["sourceRuns"]
        },
        {
          "id": "dataPanels",
          "component": "DataPanelGrid",
          "data": ["dataPanels"]
        }
      ]
    },
    {
      "id": "rankings",
      "route": "#rankings",
      "title": "榜单",
      "userGoal": "比较模型、Agent、工具和综合信号热度。",
      "layout": "segmented table view with trend sparklines",
      "regions": [
        {
          "id": "segments",
          "component": "RankingSegmentControl",
          "data": ["all", "model", "agent", "tool", "signal"]
        },
        {
          "id": "rankingTable",
          "component": "RankingTable",
          "data": ["rankingItems"]
        }
      ]
    },
    {
      "id": "calendar",
      "route": "#calendar",
      "title": "发布日历",
      "userGoal": "按时间窗口查看发布、预览、文档更新和观察信号。",
