  "componentInventory": [
    {
      "name": "AppShell",
      "responsibility": "应用框架、导航、响应式布局",
      "props": ["navigation", "activeScreen", "children"]
    },
    {
      "name": "CommandBar",
      "responsibility": "当前视图标题、全局搜索、筛选入口、外部操作",
      "props": ["title", "subtitle", "searchValue", "filters", "actions"]
    },
    {
      "name": "CategoryRail",
      "responsibility": "类别筛选",
      "props": ["categories", "categoryMeta", "selectedCategory"]
    },
    {
      "name": "SignalMatrix",
      "responsibility": "分组信号表、置信度、趋势、证据摘要和选中态",
      "props": ["signals", "selectedSignalId", "onSelectSignal"]
    },
    {
      "name": "SignalCard",
      "responsibility": "信号摘要",
      "props": ["signal", "variant", "selected"]
    },
    {
      "name": "SignalInspector",
      "responsibility": "信号详情和证据链",
      "props": ["signal"]
    },
    {
      "name": "SourceEvidenceCard",
      "responsibility": "单条信号来源证据",
      "props": ["source"]
    },
    {
      "name": "RankingTable",
      "responsibility": "榜单表格",
      "props": ["items", "kind", "sort"]
    },
    {
      "name": "TrendSparkline",
      "responsibility": "小趋势图",
      "props": ["values", "accent"]
    },
    {
      "name": "SourceHealthPanel",
      "responsibility": "来源健康摘要",
      "props": ["sources"]
    },
    {
      "name": "SourceRunList",
      "responsibility": "刷新任务列表",
      "props": ["runs"]
    },
    {
      "name": "StatusBadge",
      "responsibility": "可信度、健康状态、路线图状态",
      "props": ["tone", "label", "icon"]
    },
    {
      "name": "EmptyState",
      "responsibility": "空结果和错误兜底",
      "props": ["title", "description", "action"]
    }
  ],
  "interactions": {
    "selectSignal": {
      "trigger": "click signal row or signal card",
      "stateChange": "selectedSignalId",
      "affectedRegions": ["signalMatrix", "signalInspector", "topSignals"]
    },
    "filterCategory": {
      "trigger": "click category chip",
      "stateChange": "selectedCategory",
      "affectedRegions": ["signalMatrix", "signalList", "topSignals"]
    },
    "search": {
      "trigger": "type in command bar search input",
      "stateChange": "searchQuery",
      "affectedRegions": ["signals", "rankings", "sources"],
      "emptyState": "没有匹配信号，提供重置筛选"
    },
    "openSourceUrl": {
      "trigger": "click source or ranking external link",
      "stateChange": "none",
      "behavior": "open new tab when url exists"
    },
    "mobileOpenDetail": {
      "trigger": "tap signal card on mobile",
      "stateChange": "detailDrawerOpen",
      "affectedRegions": ["mobileSignalDetailDrawer"]
    }
  },
  "statusRules": {
    "confidenceLevel": {
      "official": { "label": "官方", "tone": "teal" },
      "docs": { "label": "文档", "tone": "blue" },
      "platform": { "label": "平台", "tone": "blue" },
      "benchmark": { "label": "榜单", "tone": "purple" },
      "social": { "label": "社区", "tone": "warning" },
      "rumor": { "label": "传闻", "tone": "danger" }
    },
    "sourceStatus": {
      "ok": { "label": "健康", "tone": "green" },
      "skipped": { "label": "待配置", "tone": "warning" },
      "error": { "label": "失败", "tone": "danger" }
    },
    "roadmapStatus": {
      "done": { "label": "已完成", "tone": "green" },
      "active": { "label": "进行中", "tone": "teal" },
      "planned": { "label": "规划中", "tone": "blue" }
    }
  },
  "responsive": {
    "desktop": {
      "minWidth": 1180,
      "layout": "sidebar plus full workspace grid",
      "overviewGrid": "central signal matrix 8 columns, inspector 4 columns, lower panels 3 columns"
    },
    "tablet": {
      "minWidth": 900,
      "layout": "compact sidebar, inspector below signal matrix when width is constrained"
    },
    "mobile": {
      "maxWidth": 640,
      "layout": "top brand bar, bottom primary nav, single column content",
      "primaryNav": ["overview", "signals", "rankings", "sources"],
      "detailPattern": "bottom drawer for signal details"
    }
  },
  "implementationPlan": [
    {
      "phase": "tokens",
      "title": "收敛设计变量",
      "tasks": ["extract CSS custom properties", "replace repeated colors", "define typography and spacing scale"]
    },
    {
      "phase": "shell",
      "title": "重建应用壳",
      "tasks": ["AppShell", "CommandBar", "responsive navigation", "mobile bottom nav"]
    },
    {
      "phase": "overview",
      "title": "升级情报总览",
      "tasks": ["SignalMatrix", "SignalInspector", "SignalDock", "RankingPanel", "SourceHealthPanel"]
    },
    {
      "phase": "workflows",
      "title": "补齐核心工作流页面",
      "tasks": ["SignalFeed", "RankingCenter", "SourceDirectory", "DataOperations"]
    },
    {
      "phase": "polish",
      "title": "补状态和移动端",
      "tasks": ["empty states", "loading states", "error states", "mobile detail drawer", "screenshot QA"]
    }
  ],
  "acceptanceCriteria": [
    "npm run lint passes",
    "npm run build passes",
    "desktop 1440px has no overlapping primary content",
    "mobile 390px has no horizontal scroll",
    "signals, rankings, sources and data pages all render from the current dataset contract",
    "source failures and missing credentials are visible and not treated as official confirmations",
    "visual structure matches design-concepts/ui-blueprint-workspace-intel.png while exact copy follows docs/ui-information-architecture.md",
    "overall background uses the existing light system theme, not a dark workspace"
  ]
}
