      "panelGap": "16px",
      "cardRadius": "8px",
      "controlRadius": "8px",
      "desktopBreakpoint": 1180,
      "tabletBreakpoint": 900,
      "mobileBreakpoint": 640
    },
    "motion": {
      "fast": "120ms ease",
      "normal": "180ms ease",
      "slow": "280ms ease",
      "reducedMotion": "disable non-essential animation"
    }
