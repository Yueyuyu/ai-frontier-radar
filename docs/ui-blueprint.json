  "product": {
    "name": "AI 前沿情报站",
    "englishName": "Frontier Intel",
    "purpose": "追踪模型、AI 编程工具、Agent、MCP / Skill 插件、榜单变化、来源健康与发布信号。",
    "primaryExperience": "持续刷新的 AI 前沿情报工作台",
    "visualReference": "design-concepts/ui-blueprint-workspace-intel.png",
    "completeUiDesign": {
      "figmaFile": "https://www.figma.com/design/BrCkDbTQn8W3LB6nm7p1KQ",
      "figmaCoverageScreenshot": "design-concepts/complete-ui/figma-coverage-map.png",
      "imagegenBoard": "design-concepts/complete-ui/imagegen-complete-ui-board.png",
      "imagegenPageDirectory": "design-concepts/complete-ui/pages"
    }
  },
  "dataSources": {
    "runtimeDataset": "/data/frontier-intel-data.json",
    "fallbackDataset": "src/data.ts",
    "typescriptContract": "src/types.ts",
    "refreshBehavior": {
      "pollMs": 60000,
      "mergeStrategy": "remote fields override fallback while empty arrays keep fallback values"
    },
    "principles": [
      "official docs and APIs confirm facts",
      "leaderboards and benchmarks rank capability",
      "GitHub Product Hunt HN Hugging Face measure ecosystem heat",
      "X is required as an early propagation signal but cannot confirm releases by itself",
      "source health is a first-class UI object"
    ],
    "sourceGroups": [
      {
        "id": "official-confirmation",
        "label": "官方确认",
        "purpose": "确认模型发布、API 上线、弃用、价格和文档变化",
        "uiUsage": ["发布日历", "信号可信度", "事实确认"],
        "sources": [
          { "name": "OpenAI News", "status": "implemented", "access": "official-page" },
          { "name": "OpenAI API Changelog", "status": "implemented", "access": "official-page" },
          { "name": "Anthropic Newsroom", "status": "planned", "access": "official-page" },
          { "name": "Claude Release Notes", "status": "implemented", "access": "official-page" },
          { "name": "Claude Code Changelog", "status": "planned", "access": "official-page" },
          { "name": "Gemini API Changelog", "status": "implemented", "access": "official-page" },
          { "name": "Gemini Blog", "status": "planned", "access": "official-page" },
          { "name": "Mistral Docs Changelog", "status": "implemented", "access": "official-page" },
          { "name": "DeepSeek API Docs", "status": "implemented", "access": "official-page" },
          { "name": "DeepSeek Models / Pricing", "status": "planned", "access": "official-page" },
          { "name": "Kimi API Docs", "status": "implemented", "access": "official-page" },
          { "name": "Qwen Blog / ModelScope", "status": "planned", "access": "official-page" },
          { "name": "ZAI Docs / BigModel", "status": "planned", "access": "official-page" }
        ]
      },
      {
        "id": "model-capability",
        "label": "模型能力",
        "purpose": "衡量模型可用性、能力、价格、上下文、模态和趋势",
        "uiUsage": ["模型地图", "模型排行", "趋势"],
        "sources": [
          { "name": "OpenRouter Models API", "status": "implemented", "access": "public-api" },
          { "name": "Artificial Analysis Data API", "status": "configured-optional", "access": "api-key", "env": ["ARTIFICIAL_ANALYSIS_API_KEY", "ARTIFICIAL_ANALYSIS_API_URL"] },
          { "name": "Arena / LMArena", "status": "planned", "access": "html-page" },
          { "name": "SWE-bench", "status": "planned", "access": "html-page" },
          { "name": "Hugging Face Hub API", "status": "implemented", "access": "public-api" },
          { "name": "Vals AI", "status": "planned", "access": "html-page" }
        ]
      },
      {
        "id": "agent-capability",
        "label": "Agent 能力",
        "purpose": "衡量浏览器、代码、电脑使用、研究类 Agent 能力",
        "uiUsage": ["Agent 市场", "Agent 榜单"],
        "sources": [
          { "name": "Steel.dev Agent Leaderboards", "status": "implemented-health-check", "access": "html-page" },
          { "name": "Agent Arena", "status": "implemented-health-check", "access": "html-page" },
          { "name": "HAL Princeton", "status": "implemented-health-check", "access": "html-page" },
          { "name": "SkillsBench", "status": "implemented-health-check", "access": "html-page" },
          { "name": "OSWorld", "status": "implemented-health-check", "access": "html-page" },
          { "name": "WebArena", "status": "implemented-health-check", "access": "html-page" }
        ]
      },
      {
        "id": "tool-ecosystem-heat",
        "label": "工具与生态热度",
        "purpose": "衡量工具、插件、MCP Server、Agent Skill 的产品和开源热度",
        "uiUsage": ["Skill / 插件", "工具榜", "生态热度"],
        "sources": [
          { "name": "GitHub REST API", "status": "implemented", "access": "public-api" },
          { "name": "OSSInsight AI Trending", "status": "planned", "access": "public-page" },
          { "name": "Product Hunt API", "status": "configured-optional", "access": "api-key", "env": ["PRODUCT_HUNT_TOKEN"] },
          { "name": "Hacker News Algolia API", "status": "implemented", "access": "public-api" },
          { "name": "Futurepedia", "status": "planned", "access": "html-page" },
          { "name": "There is An AI For That", "status": "planned", "access": "html-page" }
        ]
      },
      {
        "id": "research-trends",
        "label": "研究趋势",
        "purpose": "识别论文和研究方向变化",
        "uiUsage": ["前沿信号流", "研究型信号"],
        "sources": [
          { "name": "arXiv API", "status": "implemented", "access": "public-api" },
          { "name": "Semantic Scholar API", "status": "planned", "access": "public-api" }
        ]
      },
      {
        "id": "early-propagation",
        "label": "早期传播",
        "purpose": "识别传播热度和传闻，不能单独确认事实",
        "uiUsage": ["热度变化", "早期传闻"],
        "sources": [
          { "name": "X Recent Search", "status": "configured-optional", "access": "api-key", "env": ["X_BEARER_TOKEN"] },
          { "name": "X Filtered Stream", "status": "planned", "access": "api-key", "env": ["X_BEARER_TOKEN"] }
        ]
      }
    ],
    "scoringRules": {
      "model": [
        { "factor": "capabilityLeaderboard", "weight": 35 },
        { "factor": "apiAvailability", "weight": 20 },
        { "factor": "priceContextSpeedLatency", "weight": 15 },
        { "factor": "officialConfirmation", "weight": 15 },
        { "factor": "heatGrowth", "weight": 15 }
      ],
      "agent": [
        { "factor": "benchmarkSuccess", "weight": 40 },
        { "factor": "realSessionComplexityComputerUse", "weight": 20 },
        { "factor": "githubOrProductGrowth", "weight": 15 },
        { "factor": "xOrHnHeat", "weight": 15 },
        { "factor": "officialAvailability", "weight": 10 }
      ],
      "tool": [
        { "factor": "github28DayGrowth", "weight": 30 },
        { "factor": "productHuntOrHnHeat", "weight": 25 },
        { "factor": "xPropagation", "weight": 20 },
        { "factor": "docsAndReleaseActivity", "weight": 15 },
        { "factor": "directoryAndEcosystemDependency", "weight": 10 }
      ]
    }
  },
  "designTokens": {
    "colors": {
      "page": "#f6fbff",
      "pageGradient": "linear-gradient(115deg, rgba(255, 255, 255, 0.96), rgba(241, 250, 255, 0.94) 44%, rgba(233, 249, 255, 0.9))",
